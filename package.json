{
  "name": "pulseboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack --port 3001",
    "dev:https": "next dev --webpack --experimental-https --port 3001",
    "build": "next build --webpack",
    "build:analyze": "sh -c 'ANALYZE=true next build --webpack'",
    "start": "sh -c 'next start --port ${PORT:-3001}'",
    "start:ci": "sh -c 'HOSTNAME=127.0.0.1 PORT=3001 node .next/standalone/server.js'",
    "lint": "eslint",
    "typecheck": "next typegen && tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ci": "npm run build && playwright test",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.39.0",
    "animejs": "^4.3.6",
    "framer-motion": "^12.35.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.8.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "16.1.6",
    "@playwright/test": "^1.51.1",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-themes": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-storybook": "^10.2.16",
    "storybook": "^10.2.16",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.1"
  }
}
